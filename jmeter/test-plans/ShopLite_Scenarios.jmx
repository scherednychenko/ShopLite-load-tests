      <hashTree/>
      <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Init - Log Run Context" enabled="false">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">if (vars.get(&apos;__ctx_logged&apos;) == null) {
  log.info(&apos;Run context: runType=&apos; + vars.get(&apos;runType&apos;) + &apos;, threads=&apos; + props.get(&apos;threads&apos;) + &apos;, rampUpSec=&apos; + props.get(&apos;rampUpSec&apos;) + &apos;, durationSec=&apos; + props.get(&apos;durationSec&apos;) + &apos;, cartSize=&apos; + vars.get(&apos;cartSize&apos;))
  log.info(&apos;Target: &apos; + props.get(&apos;protocol&apos;) + &apos;://&apos; + props.get(&apos;host&apos;) + &apos;:&apos; + props.get(&apos;port&apos;) + props.get(&apos;basePath&apos;))
  vars.put(&apos;__ctx_logged&apos;,&apos;true&apos;)
}</stringProp>
      </JSR223Sampler>
      <hashTree/>
