        <hashTree/>
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Once Only - Init Context" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Init - Log Run Context" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">if (vars.get(&apos;__ctx_logged&apos;) == null) {
          def runType = vars.get(&apos;runType&apos;) ?: &apos;n/a&apos;
          def threads = props.getProperty(&apos;threads&apos;, &apos;n/a&apos;)
          def rampUpSec = props.getProperty(&apos;rampUpSec&apos;, &apos;n/a&apos;)
          def durationSec = props.getProperty(&apos;durationSec&apos;, &apos;n/a&apos;)
          def cartSize = vars.get(&apos;cartSize&apos;) ?: &apos;n/a&apos;

          log.info(&quot;Run context: runType=${runType}, threads=${threads}, rampUpSec=${rampUpSec}, durationSec=${durationSec}, cartSize=${cartSize}&quot;)

          def protocol = vars.get(&apos;protocol&apos;) ?: props.getProperty(&apos;protocol&apos;, &apos;https&apos;)
          def host = vars.get(&apos;host&apos;) ?: props.getProperty(&apos;host&apos;, &apos;localhost&apos;)
          def port = vars.get(&apos;port&apos;) ?: props.getProperty(&apos;port&apos;, &apos;443&apos;)
          def basePath = vars.get(&apos;basePath&apos;) ?: props.getProperty(&apos;basePath&apos;, &apos;&apos;)
          if (basePath &amp;&amp; !basePath.startsWith(&apos;/&apos;)) basePath = &apos;/&apos; + basePath

          def portPart = port ? &apos;:&apos; + port : &apos;&apos;
          log.info(&quot;Target: ${protocol}://${host}${portPart}${basePath}&quot;)

          vars.put(&apos;__ctx_logged&apos;, &apos;true&apos;)
        }</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="SC_Browse_Catalog" enabled="true"/>
        <hashTree>
