        <stringProp name="ThreadGroup.ramp_time">${__P(rampUpSec,30)}</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${__P(durationSec,600)}</stringProp>
